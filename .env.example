# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OpenAlex (polite pool — higher rate limits) ───────────────────────────
# Any email works. See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=your-email@example.com

# ── LLM APIs (required for Step 6: classification) ───────────────────────
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Elsevier API (optional — recovers abstracts for JDE/JHE papers) ───────
# Requires institutional IP or approved developer key:
# https://dev.elsevier.com/
ELSEVIER_API_KEY=your_elsevier_api_key_here
